function TfrmVenda.GravarVenda: Integer;
begin
  fdqExecute.Close;
  fdqExecute.SQL.Clear;
  fdqExecute.SQL.Add('INSERT INTO venda ( ');
  fdqExecute.SQL.Add('	cliente, telefone, observacao) ');
  fdqExecute.SQL.Add('VALUES (');
  fdqExecute.SQL.Add('  :cliente, :telefone, :observacao) ');
  fdqExecute.SQL.Add('RETURNING ID ');

  fdqExecute.ParamByName('Cliente').AsString := Trim(edtCliente.Text);
  fdqExecute.ParamByName('telefone').AsString := Trim(mkeTelefone.Text);
  fdqExecute.ParamByName('observacao').AsString := Trim(mmoObservacao.Lines.Text);
  fdqExecute.Open();

  Result := fdqExecute.FieldByName('id').AsInteger;
end;

procedure TfrmVenda.GravarVendaItens(const AID: Integer);
var
  LIndex: Integer;
begin
  fdqExecute.Close;
  fdqExecute.SQL.Clear;
  fdqExecute.SQL.Add('INSERT INTO venda_item ( ');
  fdqExecute.SQL.Add('	id_venda, produto, quantidade, valor) ');
  fdqExecute.SQL.Add('VALUES (');
  fdqExecute.SQL.Add('  :id_venda, :produto, :quantidade, :valor) ');

  fdqExecute.Params.ArraySize := dsProdutos.DataSet.RecordCount;

  dsProdutos.DataSet.First;
  LIndex := 0;

  while not dsProdutos.DataSet.Eof do
  begin
    fdqExecute.ParamByName('id_venda').AsIntegers[LIndex] := AID;
    fdqExecute.ParamByName('produto').AsStrings[LIndex] := dsProdutos.DataSet.FieldByName('produto').AsString.Trim;
    fdqExecute.ParamByName('quantidade').AsIntegers[LIndex] := dsProdutos.DataSet.FieldByName('quantidade').AsInteger;
    fdqExecute.ParamByName('valor').AsCurrencys[LIndex] := dsProdutos.DataSet.FieldByName('valor').AsCurrency;

    Inc(LIndex);
    dsProdutos.DataSet.Next;
  end;

  fdqExecute.Execute(dsProdutos.DataSet.RecordCount);
end;

procedure TfrmVenda.Limpar;
begin
  edtCliente.Clear;
  mkeTelefone.Clear;
  mmoObservacao.Lines.Clear;
  fdmProdutos.Close;

  lblTotalVenda.Caption := FormatCurr('R$ #,##0.00', 0);
  lblQuantidadeProdutos.Caption := 'Itens: 0';

  fdmFormaPagamento.Close;
end;

procedure TfrmVenda.OcultarTabs(APageControl: TPageControl);
var
  I: Integer;
begin
  for I := 0 to Pred(APageControl.PageCount) do
  begin
    APageControl.Pages[I].TabVisible := False;
  end;
end;

procedure TfrmVenda.Panel6Resize(Sender: TObject);
begin
  ArredondarPanel(TPanel(Sender), 20); // 20 = raio da borda
end;

procedure TfrmVenda.ArredondarPanel(APanel: TPanel; Raio: Integer);
var
  Rgn: HRGN;
begin
  Rgn := CreateRoundRectRgn(
    0, 0,
    APanel.ClientWidth,
    APanel.ClientHeight,
    Raio, Raio
  );
  SetWindowRgn(APanel.Handle, Rgn, True);
  APanel.BevelOuter := bvNone;
  APanel.ParentBackground := False;
end;

end.
