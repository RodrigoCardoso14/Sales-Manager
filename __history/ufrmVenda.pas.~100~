procedure TfrmVenda.ConsultarVendas;
begin
  FDQVenda.Close;
  FDQVenda.SQL.Clear;
  FDQVenda.SQL.Add('SELECT ');
  FDQVenda.SQL.Add('  v.id, ');
  FDQVenda.SQL.Add('  v.cliente, ');
  FDQVenda.SQL.Add('  v.created_at, ');
  FDQVenda.SQL.Add('SUM(COALESCE(i.quantidade, 0) * COALESCE(i.valor, 0)) AS total ');
  FDQVenda.SQL.Add('FROM venda v ');
  FDQVenda.SQL.Add('LEFT JOIN venda_item i ON i.id_venda = v.id ');
  FDQVenda.SQL.Add('GROUP BY v.id ');
  FDQVenda.SQL.Add('ORDER BY v.created_at ');
  FDQVenda.Open();
end;

