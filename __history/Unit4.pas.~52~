{$R *.dfm}

procedure TForm4.btnConfirmaClick(Sender: TObject);
begin
  pgcVendas.SelectNextPage(True);
end;

procedure TForm4.btnFinalizarClick(Sender: TObject);
begin
  pgcVendas.ActivePage := tsVenda;
end;

procedure TForm4.Button2Click(Sender: TObject);
begin
  dsProdutos.DataSet.Open;
  dsProdutos.DataSet.Append;
  dsProdutos.DataSet.FieldByName('Quantidade').AsInteger := 1;
  dsProdutos.DataSet.FieldByName('Valor').AsInteger := 0;
  dsProdutos.DataSet.FieldByName('Total').AsInteger := 0;
end;

procedure TForm4.btnAvancarClick(Sender: TObject);
begin
  pgcVendas.SelectNextPage(True);
end;

procedure TForm4.CancelarClick(Sender: TObject);
begin
  Limpar;
  pgcVendas.SelectNextPage(False);
end;

procedure TForm4.cxButton1Click(Sender: TObject);
begin
  {Application.CreateForm(TFrmPagamento, FrmPagamento);
  try
    FrmPagamento.ShowModal;
  finally
    FreeAndNil(FrmPagamento);
  end;   }

  dsFormaPagamento.DataSet.Open;
  dsFormaPagamento.DataSet.Append;
  dsFormaPagamento.DataSet.FieldByName('FormaPagamento').AsString := 'DINHEIRO';
  dsFormaPagamento.DataSet.FieldByName('Condicao').AsString := 'ﾀ VISTA';
  dsFormaPagamento.DataSet.FieldByName('Parcelas').AsInteger := 1;
  dsFormaPagamento.DataSet.FieldByName('RecebidoTroco').AsString := 'RECEBIDO: ' + FormatCurr('#,##0', 100) + #13#10 + 'TROCO: ' + FormatCurr('#,##0', 10);
  dsFormaPagamento.DataSet.FieldByName('Valor').AsCurrency := 90;
end;

procedure TForm4.cxButton2Click(Sender: TObject);
begin
  dsFormaPagamento.DataSet.Open;
  dsFormaPagamento.DataSet.Append;
  dsFormaPagamento.DataSet.FieldByName('FormaPagamento').AsString := 'PIX';
  dsFormaPagamento.DataSet.FieldByName('Condicao').AsString := 'ﾀ VISTA';
  dsFormaPagamento.DataSet.FieldByName('Parcelas').AsInteger := 1;
  dsFormaPagamento.DataSet.FieldByName('Valor').AsCurrency := 100;
end;

procedure TForm4.cxgrdVendaDBTableView1CustomDrawColumnHeader(
  Sender: TcxGridTableView; ACanvas: TcxCanvas;
  AViewInfo: TcxGridColumnHeaderViewInfo; var ADone: Boolean);
begin
  ACanvas.Font.Style := ACanvas.Font.Style + [fsBold];
  ACanvas.FillRect(AViewInfo.Bounds, clWhite);
  ACanvas.FrameRect(AViewInfo.Bounds, clWhite, 1, [bLeft, bRight, bTop]);
  ACanvas.DrawTexT(AViewInfo.Text, AViewInfo.TextAreaBounds, cxAlignHCenter or cxAlignVCenter);
  ADone := True;

  {if AViewInfo.State = gcsPressed then
  begin
    //AViewInfo.State := gcsNone;
    Sender.Controller.PressedColumn := nil;
    //AViewInfo.Paint(ACanvas);
    //Sender.Controller.PressedColumn := AViewInfo.Column;
    //AViewInfo.State := gcsPressed;
  end;}
end;

procedure TForm4.FDMProdutosCalcFields(DataSet: TDataSet);
begin
  DataSet.FieldByName('TOTAL').AsFloat := DataSet.FieldByName('QUANTIDADE').AsInteger * DataSet.FieldByName('VALOR').AsFloat;
  lblTotalVenda.Caption := FormatCurr('#,##0', StrToCurrDef(dsProdutos.DataSet.FieldByName('ValorTotal').AsString, 0));
end;

procedure TForm4.FormCreate(Sender: TObject);
begin
  pgcVendas.ActivePage := tsVenda;
end;

procedure TForm4.Limpar;
begin
  FDMProdutos.EmptyDataSet;
  edtCliente.Clear;
  MaskEdit1.Clear;
  Memo1.Lines.Clear;
end;

