var
  LID: Integer;
begin
  FDConnection.StartTransaction;
  try
    LID := GravarVenda;

    GravarVendaItens(LID);
    //GravarVendaPagamento(LID);

    FDConnection.Commit;
  except on E: Exception do
    begin
      FDConnection.Rollback;
      Application.MessageBox(PWideChar(
        'Falha ao tentar gravar a venda. ' + sLineBreak + sLineBreak + 'Erro: ' + E.message),
        'Erro', MB_OK + MB_ICONERROR);
    end;
  end;
end;

